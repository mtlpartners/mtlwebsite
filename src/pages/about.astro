---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About - MTL Partners LLC">
  <Navbar currentPage="/about" />
  <main class="pt-24">
    <section class="py-16 bg-charcoal-800">
      <div class="max-w-4xl mx-auto px-6">
        <h1 class="text-4xl md:text-5xl font-semibold text-white">
          About MTL Partners
        </h1>
      </div>
    </section>

    <section class="py-16 bg-charcoal-900">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl font-semibold text-white mb-6">Company Overview</h2>
        <p class="text-gray-400 mb-4">
          MTL Partners LLC is a UAE-based company registered in the Sharjah Free Zone.
        </p>
        <p class="text-gray-400">
          Founded in 2025, MTL Partners provides technical operations support, system integration, and digital infrastructure management services.
        </p>
      </div>
    </section>

    <section class="py-16 bg-charcoal-800">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl font-semibold text-white mb-6">Services</h2>
        <p class="text-gray-400 mb-6">MTL Partners provides the following services:</p>
        <ul class="space-y-4">
          {[
            { text: 'System and tool integration', icon: 'M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1' },
            { text: 'Workflow optimization', icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15' },
            { text: 'Technical operations management', icon: 'M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z' },
            { text: 'Digital infrastructure maintenance', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' }
          ].map((item) => (
            <li class="flex items-center gap-4 text-gray-300">
              <div class="w-10 h-10 rounded-lg bg-charcoal-700 border border-charcoal-600 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                </svg>
              </div>
              {item.text}
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="py-16 bg-charcoal-900">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl font-semibold text-white mb-6">Operating Model</h2>
        <p class="text-gray-400 mb-4">
          MTL Partners operates through direct working relationships with select organizations.
        </p>
        <p class="text-gray-400">
          The company operates remotely and provides support to partners across multiple regions.
        </p>
      </div>
    </section>

    <section class="py-16 bg-charcoal-800">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-2xl font-semibold text-white mb-8">Company Information</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {[
            { label: 'Founded', value: '2025', icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z' },
            { label: 'Jurisdiction', value: 'United Arab Emirates', icon: 'M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9' },
            { label: 'Registration', value: 'Sharjah Free Zone', icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4' },
            { label: 'Operating Model', value: 'Remote / International', icon: 'M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9' }
          ].map((item) => (
            <div class="bg-charcoal-700/50 border border-charcoal-600/50 rounded-lg p-5 flex items-start gap-4">
              <div class="w-10 h-10 rounded-lg bg-charcoal-600 border border-charcoal-500 flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                </svg>
              </div>
              <div>
                <p class="text-gray-500 text-sm mb-1">{item.label}</p>
                <p class="text-white font-medium">{item.value}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
